{
    "name": "tubesize",
    "private": true,
    "version": "1.1.0",
    "type": "module",
    "scripts": {
        "dev": "vite build --watch --mode development",
        "build": "vite build",
        "test": "jest",
        "test:coverage": "jest --coverage",
        "test:preview": "wslview ./coverage/lcov-report/index.html",
        "prettier:write": "pnpm exec prettier . --write",
        "pack": "pnpm run build && pnpm run generate-firefox-manifest && zip -r dist/tubesize.zip dist",
        "pack:firefox": "pnpm run build && sh ./scripts/pack-firefox.sh",
        "lint": "eslint .",
        "preview": "vite preview",
        "tsc": "tsc --noEmit -p tsconfig.app.json",
        "generate-firefox-manifest": "node ./scripts/generate-firefox-manifest.cjs",
        "release": "node ./scripts/release.cjs"
    },
    "dependencies": {
        "filesize": "^11.0.13",
        "humanize-duration": "^3.33.2",
        "m3u8-parser": "^7.2.0",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "ts-node": "^10.9.2",
        "webextension-polyfill": "^0.12.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.1",
        "@types/chrome": "^0.1.37",
        "@types/filesize": "^5.0.2",
        "@types/humanize-duration": "^3.27.4",
        "@types/jest": "^30.0.0",
        "@types/m3u8-parser": "^7.2.6",
        "@types/ms": "^2.1.0",
        "@types/node": "^24.10.1",
        "@types/react": "^19.2.7",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.1",
        "babel-plugin-react-compiler": "^1.0.0",
        "eslint": "^9.39.1",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.4.24",
        "globals": "^16.5.0",
        "jest": "^30.3.0",
        "jest-extended": "^7.0.0",
        "prettier": "^3.8.1",
        "ts-jest": "^29.4.6",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.48.0",
        "vite": "^7.3.1",
        "vite-plugin-web-extension": "^4.5.0"
    }
}
