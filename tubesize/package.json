{
    "name": "tubesize",
    "private": true,
    "version": "2.2.1",
    "type": "module",
    "scripts": {
        "dev": "vite build --watch --mode development",
        "build": "vite build",
        "test": "jest",
        "test:coverage": "jest --coverage",
        "test:preview": "wslview ./coverage/lcov-report/index.html",
        "prettier:write": "pnpm exec prettier . --write",
        "pack": "pnpm run build && zip -r dist/tubesize.zip dist",
        "pack:firefox": "pnpm run build && sh ./scripts/pack-firefox.sh",
        "lint": "eslint .",
        "preview": "vite preview",
        "tsc": "tsc --noEmit -p tsconfig.app.json",
        "release": "node ./scripts/release.cjs",
        "knip": "knip"
    },
    "knip": {
        "entry": [
            "src/background.ts",
            "src/content.ts",
            "scripts/generate-firefox-manifest.cjs"
        ],
        "ignoreBinaries": [
            "wslview"
        ],
        "vite": true,
        "jest": true
    },
    "dependencies": {
        "filesize": "^11.0.16",
        "humanize-duration": "^3.33.2",
        "m3u8-parser": "^7.2.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/chrome": "^0.1.40",
        "@types/humanize-duration": "^3.27.4",
        "@types/jest": "^30.0.0",
        "@types/m3u8-parser": "^7.2.6",
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.7",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "babel-plugin-react-compiler": "^1.0.0",
        "eslint": "^10.2.1",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "eslint-plugin-unicorn": "^64.0.0",
        "globals": "^17.5.0",
        "jest": "^30.3.0",
        "jest-extended": "^7.0.0",
        "knip": "^6.6.1",
        "prettier": "^3.8.3",
        "ts-jest": "^29.4.9",
        "typescript": "~6.0.3",
        "typescript-eslint": "^8.59.0",
        "vite": "^8.0.10",
        "vite-plugin-web-extension": "^4.5.1"
    }
}
