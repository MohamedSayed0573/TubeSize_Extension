{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run pnpm lint",
            "type": "shell",
            "command": "pnpm lint",
            "group": "test",
            "problemMatcher": "$eslint-stylish",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        }
    ]
}
