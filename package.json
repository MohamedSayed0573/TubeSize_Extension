{
    "name": "tubesize",
    "private": true,
    "version": "2.3.1",
    "type": "module",
    "packageManager": "pnpm@11.2.2",
    "scripts": {
        "build": "tsc -b && vite build",
        "dev": "vite",
        "test": "jest",
        "test:coverage": "jest --coverage",
        "test:preview": "wslview ./coverage/lcov-report/index.html",
        "prettier:write": "pnpm exec prettier . --write",
        "pack": "rm -rf dist && pnpm run build && zip -r dist/tubesize.zip dist",
        "pack:firefox": "rm -rf dist_firefox && pnpm run build && sh ./scripts/pack-firefox.sh",
        "lint": "eslint .",
        "preview": "vite preview",
        "tsc": "tsc --noEmit",
        "release": "node ./scripts/release.cjs",
        "knip": "knip",
        "prepare": "husky",
        "lint-staged": "lint-staged"
    },
    "lint-staged": {
        "*.{css,html,js,jsx,json,md,ts,tsx}": "prettier --write"
    },
    "knip": {
        "entry": [
            "src/background.ts",
            "src/content.ts",
            "src/observer.ts",
            "scripts/generate-firefox-manifest.cjs"
        ],
        "ignoreBinaries": [
            "wslview"
        ],
        "vite": true,
        "jest": true
    },
    "dependencies": {
        "@fontsource-variable/jetbrains-mono": "^5.2.8",
        "filesize": "^11.0.17",
        "humanize-duration": "^3.33.2",
        "m3u8-parser": "^7.2.0",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-router": "^8.0.0",
        "recharts": "^3.8.1",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@crxjs/vite-plugin": "^2.6.1",
        "@eslint/js": "^10.0.1",
        "@types/chrome": "^0.1.43",
        "@types/humanize-duration": "^3.27.4",
        "@types/jest": "^30.0.0",
        "@types/m3u8-parser": "^7.2.6",
        "@types/node": "^25.9.3",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.2",
        "eslint": "^10.5.0",
        "eslint-plugin-promise": "^7.3.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.3",
        "eslint-plugin-unicorn": "^67.0.0",
        "globals": "^17.6.0",
        "husky": "^9.1.7",
        "jest": "^30.4.2",
        "jest-extended": "^7.0.0",
        "knip": "^6.17.1",
        "lint-staged": "^17.0.7",
        "prettier": "^3.8.4",
        "ts-jest": "^29.4.11",
        "typescript": "~6.0.3",
        "typescript-eslint": "^8.61.1",
        "vite": "^8.0.16",
        "vite-plugin-zip-pack": "^1.2.4"
    }
}
