{
    "manifest_version": 3,
    "name": "TubeSize",
    "version": "1.0.0",
    "description": "View file size data for YouTube videos across different quality levels.",

    "permissions": ["activeTab", "storage"],

    "icons": {
        "16": "icons/icon-16.png",
        "32": "icons/icon-32.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },

    "action": {
        "default_popup": "index.html"
    },

    "background": {
        "scripts": ["src/background.js"]
    },

    "host_permissions": [
        "https://*.youtube.com/*",
        "https://*.twitch.tv/*",
        "https://usher.ttvnw.net/api/v2/channel/hls/*",
        "https://gql.twitch.tv/gql/*"
    ],

    "content_scripts": [
        {
            "matches": ["https://*.youtube.com/*", "https://*.twitch.tv/*"],
            "js": ["src/content.js"]
        }
    ],

    "commands": {
        "_execute_action": {
            "suggested_key": {
                "default": "Ctrl+Shift+0",
                "mac": "Command+Shift+0"
            },
            "description": "Open the TubeSize popup"
        }
    },

    "browser_specific_settings": {
        "gecko": {
            "id": "tubesize@mohammedsayed.dev",
            "strict_min_version": "109.0"
        }
    }
}
